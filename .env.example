# API 配置
API_HOST=0.0.0.0
API_PORT=8000

# 数据库配置 (SQLite)
DATABASE_URL=sqlite:///./data/wechat.db

# 调度配置
CRAWL_INTERVAL_HOURS=6
CLEANUP_DAYS=30

# 浏览器配置
HEADLESS_BROWSER=true
MAX_BROWSERS=3
SCROLL_DELAY_MS=2000
MAX_PAGES_PER_CRAWL=10

# 日志配置
LOG_LEVEL=INFO
LOG_DIR=./logs

# 文件存储
MARKDOWN_DIR=./data/markdown
AUTH_SESSIONS_DIR=./data/auth_sessions
